# ==========================================
# 智能客服 Agent 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# ==========================================

# LLM 配置
# LLM 提供商：ollama / siliconflow（当前固定使用 siliconflow）
LLM_PROVIDER=siliconflow

# 生成模型（用于生成回复）
LLM_MODEL=Qwen/Qwen3.5-9B

# 调度模型（用于意图识别、工具调用决策）
DISPATCH_MODEL=deepseek-ai/DeepSeek-R1-0528-Qwen3-8B

# SiliconFlow 配置（云端 LLM）
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Ollama 配置（本地嵌入模型）
# Ollama 服务地址（本地: http://localhost:11434，Docker: http://ollama:11434）
OLLAMA_BASE_URL=http://localhost:11434

# 嵌入模型配置
# 嵌入模型名称（需先在 Ollama 中拉取）
EMBEDDING_MODEL=bge-m3


# Chroma 向量库配置
# Chroma 持久化目录
CHROMA_DIR=./chroma_db

# PostgreSQL 配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_DB=kefu_agent

# LangSmith 追踪（可选）
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=kefu-agent
